{
  "name": "@codeimage/dom-export",
  "version": "1.11.5",
  "type": "module",
  "description": "Generates an image from a DOM node using HTML5 canvas and SVG.",
  "main": "./dist/dom-export.js",
  "module": "./dist/dom-export.js",
  "types": "./dist/public-api.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/public-api.d.ts",
      "default": "./dist/dom-export.js"
    }
  },
  "keywords": [
    "screenshot",
    "capture",
    "canvas",
    "html",
    "dom",
    "image",
    "vector",
    "svg"
  ],
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "pre-commit-format": "oxfmt",
    "pre-commit-eslint": "oxlint --fix",
    "build": "vite build",
    "test": "vitest",
    "typecheck:ci": "tsc --skipLibCheck --project tsconfig.dts.json"
  },
  "lint-staged": {
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "oxfmt"
    ],
    "*.ts": [
      "oxlint --fix"
    ]
  },
  "license": "MIT",
  "author": {
    "name": "bubkooo",
    "email": "bubkoo.wy@gmail.com"
  },
  "contributors": [
    {
      "name": "bubkooo",
      "email": "bubkoo.wy@gmail.com"
    },
    {
      "name": "OiNutter",
      "email": "will@oinutter.co.uk"
    }
  ],
  "devDependencies": {
    "@types/node": "catalog:next",
    "happy-dom": "8.1.1",
    "lint-staged": "^13.2.1",
    "oxfmt": "catalog:next",
    "oxlint": "catalog:next",
    "prettier": "^2.8.7",
    "rimraf": "^3.0.2",
    "tslib": "^2.6.2",
    "typescript": "catalog:next",
    "vite": "catalog:next",
    "vite-plugin-dts": "catalog:next",
    "vitest": "catalog:next"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riccardoperra/codeimage-export.git"
  },
  "dependencies": {
    "@solid-primitives/platform": "^0.0.101",
    "solid-js": "catalog:next"
  },
  "peerDependencies": {
    "@solid-primitives/platform": "^0.0.101",
    "solid-js": "catalog:next"
  },
  "engines": {
    "node": ">=24"
  }
}
