{
  "name": "@codeimage/ui",
  "version": "0.10.6",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "source": "./src/index.tsx",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "browser": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
      },
      "require": "./dist/cjs/index.js",
      "node": "./dist/cjs/index.js"
    },
    "./themes/darkTheme": {
      "types": "./dist/types/lib/themes/dark-theme.css.d.ts",
      "default": "./dist/esm/darkTheme.css.vanilla.js"
    },
    "./themes/lightTheme": {
      "types": "./dist/types/lib/themes/light-theme.css.d.ts",
      "default": "./dist/esm/lightTheme.css.vanilla.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/types/index.d.ts"
      ],
      "themes/darkTheme": [
        "./dist/types/lib/themes/dark-theme.css.d.ts"
      ],
      "themes/lightTheme": [
        "./dist/types/lib/themes/light-theme.css.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "vite serve ./dev --host",
    "build": "tsx ./tools/build.ts",
    "build:dev": "vite build ./dev",
    "build:vite": "vite build",
    "build:watch": "vite build --watch",
    "pre-commit": "lint-staged --relative",
    "pre-commit-format": "oxfmt",
    "pre-commit-eslint": "oxlint --fix",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit --skipLibCheck --project tsconfig.json",
    "typecheck:ci": "tsc --skipLibCheck --project tsconfig.dts.json"
  },
  "peerDependencies": {
    "@floating-ui/core": "^1.0.1",
    "@floating-ui/dom": "^1.0.1",
    "@solid-primitives/props": "^3.1.4",
    "@solid-primitives/refs": "^1.0.2",
    "@solid-primitives/utils": "^6.0.0",
    "@vanilla-extract/css": "^1.11.0",
    "@vanilla-extract/dynamic": "^2.0.3",
    "@vanilla-extract/recipes": "^0.4.0",
    "@vanilla-extract/sprinkles": "^1.5.2",
    "clsx": "^1.2.1",
    "solid-headless": "^0.13.0",
    "solid-js": "catalog:next",
    "solid-use": "^0.7.2"
  },
  "dependencies": {
    "@codeimage/locale": "workspace:*",
    "@floating-ui/core": "^1.5.0",
    "@floating-ui/dom": "^1.5.3",
    "@motionone/solid": "^10.16.2",
    "@rollup/plugin-typescript": "^12.3.0",
    "@solid-aria/types": "^0.1.4",
    "@solid-aria/utils": "^0.2.1",
    "@solid-primitives/props": "^3.2.3",
    "@solid-primitives/refs": "^1.1.3",
    "@solid-primitives/utils": "^6.4.0",
    "@vanilla-extract/css": "^1.20.0",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/private": "^1.0.9",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "clsx": "^2.1.1",
    "solid-headless": "^0.13.1",
    "solid-toast": "^0.5.0",
    "solid-use": "^0.9.1"
  },
  "devDependencies": {
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "catalog:next",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "@vanilla-extract/vite-plugin": "^5.2.1",
    "chalk": "^5.6.2",
    "csstype": "^3.2.3",
    "merge-anything": "^6.0.6",
    "oxfmt": "catalog:next",
    "oxlint": "catalog:next",
    "pretty-ms": "9.3.0",
    "rimraf": "catalog:next",
    "rollup": "^4.60.0",
    "rollup-plugin-import-css": "^4.2.0",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-preset-solid": "^3.0.0",
    "solid-js": "catalog:next",
    "typescript": "^6.0.2",
    "vite": "catalog:next",
    "vite-plugin-dts": "catalog:next",
    "vite-plugin-solid": "catalog:next"
  },
  "engines": {
    "node": ">=24"
  }
}
