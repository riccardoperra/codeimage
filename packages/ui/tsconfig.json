{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "noUnusedLocals": true,
    "sourceMap": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsxImportSource": "solid-js",
    "preserveSymlinks": true,
    "types": ["@types/node"]
  },
  "include": ["./src"]
}
