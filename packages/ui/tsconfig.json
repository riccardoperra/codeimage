{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noUnusedLocals": true,
    "sourceMap": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsxImportSource": "solid-js",
    "types": ["node"]
  },
  "include": ["./src"]
}
