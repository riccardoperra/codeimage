{
  "extends": "fastify-tsconfig",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": false,
    "moduleResolution": "nodenext",
    "module": "NodeNext",
    "target": "ESNext",
    "types": ["@types/node", "./src/common/domainFunctions/functions.d.ts"]
  },
  "include": ["./src/**/*.ts"]
}
